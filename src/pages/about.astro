---
import educations from "../collections/educations.json";
import experiences from "../collections/experiences.json";
import AboutExperience from "../components/about-experience.astro";
import Card from "../components/card.astro";
import PageHeading from "../components/page-heading.astro";
import Layout from "../layouts/main.astro";
---

<Layout title="Sobre mim">
  <section class="relative z-20 max-w-2xl mx-auto my-12 px-7 lg:px-0">
    <PageHeading
      title="Sobre mim"
      description={`
        Sou Guilherme França, desenvolvedor de software em São Paulo, especializado em transformar desafios de negócio em soluções digitais eficientes, escaláveis e orientadas a resultado.
      `}
    />

    <img
      src="/assets/images/about.png"
      class="relative z-30 w-full my-10 rounded-xl"
      alt="Sobre"
    />

    <PageHeading
      description={`
        Tenho mais de 10 anos de experiência em tecnologia, atuando de ponta a
        ponta no desenvolvimento de soluções digitais, engenharia de dados e
        liderança técnica. Minha carreira é formada pela entrega de sistemas
        escaláveis que unem inovação, eficiência e valor agregado ao cliente.
      `}
    />

    <h2
      class="mt-5 mb-2 text-2xl font-bold lg:mt-10 sm:mt-6 dark:text-neutral-200"
    >
      Experiências profissionais
    </h2>
    <div class="px-5 py-10">
      {
        experiences.map((experience) => {
          return (
            <div class="pb-10 border-l border-gray-200 last:border-l-0 dark:border-neutral-700">
              <AboutExperience
                dates={experience.dates}
                role={experience.role}
                company={experience.company}
                description={experience.description}
                logo={experience.logo}
              />
            </div>
          );
        })
      }
    </div>

    <h2 class="mb-2 text-2xl font-bold lg:mt-5 sm:mt-6 dark:text-neutral-200">
      Educação
    </h2>

    <div class="z-50 flex flex-col items-stretch w-full gap-5 my-8">
      {
        educations.map((education) => (
          <Card
            title={education.title}
            description={education.description}
            footer={education.footer}
          />
        ))
      }
    </div>
  </section>
</Layout>
